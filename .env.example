# Email Configuration for Contact Form
# Copy this file to .env.local and fill in your actual values

# Public site URL (used for metadataBase, sitemap.xml, robots.txt)
# Prefer no trailing slash.
NEXT_PUBLIC_SITE_URL=https://farok.me

# Gmail account that will send emails
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# See EMAIL_SETUP.md for instructions on how to generate this
EMAIL_PASS=your-app-password-here
